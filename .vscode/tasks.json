{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Python: 現在のファイルを実行",
      "type": "shell",
      "command": "${config:python.defaultInterpreterPath}",
      "args": ["-u", "${file}"],
      "options": {
        "cwd": "${fileDirname}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
